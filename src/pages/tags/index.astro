---
import Base from "@/layouts/Base.astro";
import Tag from "@/components/Tag.astro";
import { getAllPosts, getTagCounts } from "@/data/post";

const posts = await getAllPosts();
const tags = getTagCounts(posts);

const meta = {
	title: "Tags",
	description: "Post archives by tag.",
};
---

<Base meta={meta}>
	<section class="page-head">
		<div class="t-eyebrow t-eyebrow--accent">Tags</div>
		<h1>All tags</h1>
		<p class="lede">Browse posts by topic.</p>
	</section>

	<div class="tag-list">
		{tags.map(([name, count]) => <Tag name={name} as="a" count={count} />)}
	</div>
</Base>

<style>
	.page-head {
		margin-bottom: 36px;
	}
	.page-head h1 {
		font-family: var(--font-sans);
		font-size: var(--text-4xl);
		font-weight: 510;
		line-height: 1.02;
		letter-spacing: -1.056px;
		color: var(--fg1);
		font-feature-settings: "cv01", "ss03";
		margin: 12px 0 16px;
	}
	.page-head .lede {
		font-family: var(--font-sans);
		font-size: var(--text-lg);
		color: var(--fg3);
		margin: 0;
	}
	.tag-list {
		display: flex;
		gap: 8px;
		flex-wrap: wrap;
	}
</style>
