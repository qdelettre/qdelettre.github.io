---
import type { GetStaticPaths, Page } from "astro";
import { render } from "astro:content";

import Base from "@/layouts/Base.astro";
import Search from "@/components/Search.astro";
import PostRow from "@/components/PostRow.astro";
import { getAllPosts, groupByYear, type Post } from "@/data/post";

export const getStaticPaths = (async ({ paginate }) => {
	const posts = await getAllPosts();
	return paginate(posts, { pageSize: 10 });
}) satisfies GetStaticPaths;

interface Props {
	page: Page<Post>;
}
const { page } = Astro.props;
const groups = groupByYear(page.data);

const enrichedGroups = await Promise.all(
	groups.map(async (g) => ({
		year: g.year,
		posts: await Promise.all(
			g.posts.map(async (p) => ({
				post: p,
				readingTime: (await render(p)).remarkPluginFrontmatter?.readingTime,
			})),
		),
	})),
);

const meta = {
	title: "Blog",
	description: "Notes, lists, and the occasional rant.",
};
---

<Base meta={meta} searchHint>
	<section class="page-head">
		<h1>Notes, lists, and<br />the occasional rant.</h1>
	</section>

	<Search />

	{
		enrichedGroups.map((g) => (
			<div class="year-group" data-year-group>
				<div class="year-head">
					<span class="year" data-testid="year-label">
						{g.year}
					</span>
					<span class="year-count">{g.posts.length} posts</span>
					<span class="rule" />
				</div>
				{g.posts.map(({ post, readingTime }) => (
					<div data-tags={post.data.tags.join(",")}>
						<PostRow post={post} variant="index" readingTime={readingTime} />
					</div>
				))}
			</div>
		))
	}

	{
		(page.url.prev || page.url.next) && (
			<nav class="pager">
				{page.url.prev ? <a href={page.url.prev}>← newer</a> : <span />}
				{page.url.next ? <a href={page.url.next}>older →</a> : <span />}
			</nav>
		)
	}
</Base>

<style>
	.page-head {
		margin-bottom: 36px;
	}
	.page-head h1 {
		font-family: var(--font-sans);
		font-size: var(--text-4xl);
		font-weight: 510;
		line-height: 1.02;
		letter-spacing: -1.056px;
		color: var(--fg1);
		font-feature-settings: "cv01", "ss03";
		margin: 12px 0 16px;
	}
	.page-head .lede {
		font-family: var(--font-sans);
		font-size: var(--text-lg);
		font-weight: 400;
		line-height: 1.55;
		color: var(--fg3);
		max-width: 560px;
		margin: 0;
	}
	.year-head {
		display: flex;
		align-items: baseline;
		gap: 14px;
		margin: 32px 0 8px;
	}
	.year-head .year {
		font-family: var(--font-sans);
		font-size: var(--text-2xl);
		font-weight: 510;
		color: var(--fg1);
		letter-spacing: -0.288px;
	}
	.year-head .year-count {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		font-weight: 510;
		color: var(--fg4);
	}
	.year-head .rule {
		flex: 1;
		height: 1px;
		background: var(--line-subtle);
	}
	.pager {
		display: flex;
		justify-content: space-between;
		margin-top: 32px;
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		font-weight: 510;
		color: var(--fg3);
	}
	.pager a {
		color: var(--fg3);
		text-decoration: none;
		transition: color 120ms;
	}
	.pager a:hover {
		color: var(--fg1);
	}
</style>
