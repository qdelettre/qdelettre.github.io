---
import Base from "@/layouts/Base.astro";
import Timeline from "@/components/Timeline.astro";
import LinkCard from "@/components/LinkCard.astro";
import { OFFICE_HOURS_LABEL } from "@/utils/office-hours";

const meta = {
	title: "About",
	description: "Fullstack engineer, based in France.",
};

const timeline = [
	{
		when: "2023 — now",
		role: "Fullstack Engineer",
		where: "Convelio — art logistics platform - PHP/Angular",
	},
	{
		when: "2018 — 2023",
		role: "Frontend Engineer",
		where: "Airbus Defence & Space, LiveAction — Angular",
		past: true,
	},
	{
		when: "2014 — 2018",
		role: "Fullstack Engineer",
		where: "Preventeo - PHP/JS",
		past: true,
	},
	{
		when: "2012 — 2014",
		role: "Bioinformatics Engineer",
		where: "CNRS",
		past: true,
	},
];
---

<Base meta={meta}>
	<section class="about-head">
		<div>
			<h1>Fullstack engineer</h1>
			<p class="lede">
				I build for the web. I read more books than I finish. I'm happiest when the scope is small
				and the feedback loop is short.
			</p>
		</div>
		<div class="hero-identity">
			<span class="brand-mark brand-mark--hero" aria-hidden="true" transition:name="brand-mark">
				<svg width="100%" height="100%" viewBox="0 0 32 32">
					<circle
						cx="16"
						cy="16"
						r="15.5"
						fill="#18191d"
						stroke="var(--accent)"
						stroke-width="1"
						vector-effect="non-scaling-stroke"></circle>
					<text
						x="16"
						y="20"
						text-anchor="middle"
						fill="#f7f8f8"
						font-family="ui-monospace, 'JetBrains Mono', Menlo, Consolas, monospace"
						font-size="13"
						font-weight="500"
						letter-spacing="-0.5">qd</text
					>
				</svg>
			</span>
			<a
				class="status-dot-link status-dot-link--hero"
				href="mailto:quentin.delettre@pm.me"
				aria-label={`Email Quentin — ${OFFICE_HOURS_LABEL}`}
				transition:name="brand-status-dot"
			>
				<span class="dot status-dot-halo"></span>
			</a>
		</div>
	</section>

	<div class="prose">
		<p>
			I've been writing code professionally for a decade, both on the frontend (Angular) and the
			backend (PHP) — now whatever the team needs. I care about the invisible parts: types, tests,
			tooling, the feel of pressing a key and having something happen instantly.
		</p>
		<p>
			Outside of that, I mess with LLMs, continuous integration, and I try to finish a book
			occasionally.
		</p>
	</div>

	<section class="block">
		<div class="block-head"><h2 class="t-eyebrow">Trajectory</h2><span class="rule"></span></div>
		<Timeline items={timeline} />
	</section>

	<section class="block">
		<div class="block-head"><h2 class="t-eyebrow">Elsewhere</h2><span class="rule"></span></div>
		<div class="links-grid">
			<LinkCard href="https://github.com/qdelettre" label="GitHub" handle="@qdelettre" external>
				<svg
					slot="icon"
					width="15"
					height="15"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.75"
				>
					<path
						d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
					></path>
				</svg>
			</LinkCard>
			<LinkCard href="mailto:quentin.delettre@pm.me" label="Email" handle="quentin.delettre@pm.me">
				<svg
					slot="icon"
					width="15"
					height="15"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.75"
				>
					<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
					></path>
					<polyline points="22,6 12,13 2,6"></polyline>
				</svg>
			</LinkCard>
			<LinkCard href="/rss.xml" label="RSS" handle="/rss.xml">
				<svg
					slot="icon"
					width="15"
					height="15"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.75"
				>
					<path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle
						cx="5"
						cy="19"
						r="1"></circle>
				</svg>
			</LinkCard>
			<LinkCard
				href="https://www.linkedin.com/in/quentindelettre/"
				label="LinkedIn"
				handle="/in/quentindelettre"
				external
			>
				<svg
					slot="icon"
					width="15"
					height="15"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.75"
				>
					<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"></path>
					<rect x="2" y="9" width="4" height="12"></rect>
					<circle cx="4" cy="4" r="2"></circle>
				</svg>
			</LinkCard>
		</div>
	</section>

	<section class="block">
		<div class="block-head"><h2 class="t-eyebrow">Colophon</h2><span class="rule"></span></div>
		<dl class="facts">
			<dt>Based</dt><dd>France</dd>
			<dt>Built with</dt><dd>
				<code>astro</code> · <code>tailwindcss</code> · <code>typescript</code>
			</dd>
			<dt>Hosted</dt><dd>GitHub Pages</dd>
			<dt>Typeface</dt><dd>Inter Variable · JetBrains Mono</dd>
			<dt>Source</dt><dd><code>github.com/qdelettre/qdelettre.github.io</code></dd>
		</dl>
	</section>
</Base>

<style>
	.about-head {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		grid-template-areas:
			"hero title"
			"lede lede";
		column-gap: var(--space-md);
		row-gap: var(--space-lg);
		align-items: center;
		margin-bottom: var(--space-xl);
	}
	.about-head > div:not(.hero-identity) {
		display: contents;
	}
	.about-head .lede {
		grid-area: lede;
		font-family: var(--font-sans);
		font-size: var(--text-lg);
		font-weight: 400;
		line-height: 1.6;
		color: var(--fg2);
		margin: 0;
	}
	.about-head h1 {
		grid-area: title;
		font-family: var(--font-sans);
		font-size: var(--text-4xl);
		font-weight: 510;
		line-height: 1;
		letter-spacing: -1.056px;
		color: var(--fg1);
		font-feature-settings: "cv01", "ss03";
		margin: 0;
		text-wrap: balance;
	}
	.brand-mark--hero {
		width: 100%;
		height: 100%;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		box-shadow: 0 0 24px -6px color-mix(in oklab, var(--accent) 40%, transparent);
	}
	.brand-mark--hero svg {
		display: block;
	}
	.hero-identity {
		grid-area: hero;
		position: relative;
		width: clamp(72px, 18vw, 110px);
		aspect-ratio: 1;
	}
	.status-dot-link--hero {
		position: absolute;
		bottom: 2px;
		right: 2px;
		width: 22px;
		height: 22px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		text-decoration: none;
	}
	.status-dot-link--hero::after {
		content: "";
		position: absolute;
		inset: -9px;
		border-radius: 50%;
	}
	.status-dot-link--hero .dot {
		width: 16px;
		height: 16px;
		border-radius: 50%;
		box-shadow: 0 0 0 4px var(--bg-app);
	}
	.prose {
		max-width: 620px;
	}
	.prose p {
		font-family: var(--font-sans);
		font-size: var(--text-base);
		font-weight: 400;
		line-height: 1.7;
		color: var(--fg2);
		letter-spacing: -0.13px;
		margin: 0 0 18px;
	}
	.prose p a {
		color: var(--fg1);
		border-bottom: 1px solid var(--accent);
		text-decoration: none;
		padding-bottom: 1px;
		transition: color 120ms;
	}
	.prose p a:hover {
		color: var(--accent-hover);
	}
	section.block {
		margin-top: var(--space-2xl);
	}
	.block-head {
		display: flex;
		align-items: baseline;
		gap: 14px;
		margin-bottom: 20px;
	}
	.block-head .rule {
		flex: 1;
		height: 1px;
		background: var(--line-subtle);
	}
	.links-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 10px;
	}
	dl.facts {
		display: grid;
		grid-template-columns: 90px 1fr;
		gap: 10px 20px;
		margin: 0;
	}
	dl.facts dt {
		font-family: var(--font-sans);
		font-size: var(--text-xs);
		font-weight: 510;
		color: var(--fg3);
		text-transform: uppercase;
		letter-spacing: 0.5px;
		padding-top: 2px;
	}
	dl.facts dd {
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		font-weight: 400;
		color: var(--fg1);
		margin: 0;
	}
	dl.facts dd code {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--fg2);
		background: var(--surface-03);
		padding: 1px 5px;
		border-radius: 3px;
		border: 1px solid var(--line-subtle);
		overflow-wrap: anywhere;
	}
</style>
