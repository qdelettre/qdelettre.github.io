---
import { siteConfig } from "@/site.config";

interface Props {
	searchHint?: boolean;
}
const { searchHint = false } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site" data-testid="site-footer">
	<span>© {year} {siteConfig.author}</span>
	<span class="right">
		<a href="/rss.xml">RSS</a>
		<span class="sep">·</span>
		<a href={siteConfig.socials.github}>GitHub</a>
		{
			searchHint && (
				<>
					<span class="sep">·</span>
					<a class="hint-link" href="/posts/">
						<span class="kbd" data-kbd="K">
							⌘K
						</span>
						<span> to search</span>
					</a>
				</>
			)
		}
	</span>
</footer>

<script>
	import { navigate } from "astro:transitions/client";

	async function openSearch() {
		await navigate("/posts/");
		document.getElementById("site-search")?.focus();
	}

	// Document-level keydown: bind once; re-query inside so soft-navs don't leave
	// us with stale closures. Skip when a search input is already on the page
	// (Search.astro has its own handler that focuses the input directly).
	document.addEventListener("keydown", (e) => {
		if (!(e.metaKey || e.ctrlKey) || e.key.toLowerCase() !== "k") return;
		if (document.getElementById("site-search")) return;
		if (!document.querySelector("a.hint-link")) return;
		e.preventDefault();
		void openSearch();
	});

	function initPageBehavior() {
		// Hint click: route via navigate() so we can focus after arrival.
		const hintLink = document.querySelector<HTMLAnchorElement>("a.hint-link");
		if (hintLink && !document.getElementById("site-search")) {
			hintLink.addEventListener("click", (e) => {
				// Let middle-click / cmd-click / shift-click fall through to the browser (new tab).
				if (e.metaKey || e.ctrlKey || e.shiftKey || e.button !== 0) return;
				e.preventDefault();
				void openSearch();
			});
		}

		// Labels are SSR'd as `⌘K` / `⌘ K` for Mac users (~majority of devs).
		// On non-Mac, rewrite to `Ctrl K` once the client knows its platform.
		if (!/mac/i.test(navigator.userAgent)) {
			document.querySelectorAll<HTMLElement>("[data-kbd]").forEach((el) => {
				const key = el.dataset.kbd ?? "K";
				el.textContent = `Ctrl ${key}`;
			});
		}
	}
	// Run at module load for the initial page, then on every soft-nav swap
	// (astro:after-swap does NOT fire on initial load — no dup).
	initPageBehavior();
	document.addEventListener("astro:after-swap", initPageBehavior);
</script>

<style>
	footer.site {
		margin-top: var(--space-2xl);
		padding-top: 28px;
		border-top: 1px solid var(--line-subtle);
		display: flex;
		justify-content: space-between;
		font-family: var(--font-sans);
		font-size: var(--text-xs);
		font-weight: 510;
		color: var(--fg4);
	}
	footer.site a {
		color: var(--fg3);
		text-decoration: none;
		transition: color 120ms;
	}
	footer.site a:hover {
		color: var(--fg1);
	}
	.right {
		display: inline-flex;
		align-items: center;
		gap: 6px;
	}
	.sep {
		color: var(--fg4);
	}
	.hint-link {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		color: inherit;
		text-decoration: none;
	}
	.hint-link:hover .kbd {
		color: var(--fg1);
		border-color: var(--line-strong);
	}
	.kbd {
		font-family: var(--font-mono);
		font-size: var(--text-2xs);
		font-weight: 510;
		background: var(--surface-03);
		border: 1px solid var(--line-subtle);
		padding: 1px 5px;
		border-radius: 3px;
		color: var(--fg3);
	}
</style>
