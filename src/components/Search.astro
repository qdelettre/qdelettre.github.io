---
import { getAllPosts, getUniqueTags } from "@/data/post";
import { tagColorVar } from "@/utils/tag-color";

const posts = await getAllPosts();
const count = posts.length;
const tags = getUniqueTags(posts);
const tagsWithColors = tags.map((t) => ({
	name: t,
	color: tagColorVar(t),
	count: posts.filter((p) => p.data.tags.includes(t)).length,
}));
---

<div class="toolbar">
	<label class="search" for="site-search">
		<svg
			width="13"
			height="13"
			viewBox="0 0 24 24"
			fill="none"
			stroke="var(--fg3)"
			stroke-width="1.75"
			aria-hidden="true"
		>
			<circle cx="11" cy="11" r="7"></circle>
			<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
		</svg>
		<input id="site-search" type="search" placeholder="Search posts…" autocomplete="off" />
		<span class="kbd-mini" data-kbd="K">⌘ K</span>
	</label>
	<span class="count" data-count={count}>{count} posts</span>
</div>

<div class="filters" data-filters>
	<button type="button" class="filter-tag active" data-tag="__all"
		>All <span class="num">{count}</span></button
	>
	{
		tagsWithColors.map((t) => (
			<button type="button" class="filter-tag" data-tag={t.name}>
				<span class="swatch" style={`background:${t.color}`} />
				{t.name} <span class="num">{t.count}</span>
			</button>
		))
	}
</div>

<div class="search-results" data-search-results hidden></div>

<script>
	function escapeAttr(s: string): string {
		return s.replace(/&/g, "&amp;").replace(/"/g, "&quot;").replace(/</g, "&lt;");
	}
	function escapeText(s: string): string {
		return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
	}

	// Pagefind module cache survives across soft-navs (module-scope).
	type Pagefind = typeof import("/pagefind/pagefind.js");
	let pagefind: Pagefind | null = null;
	async function ensurePagefind(): Promise<Pagefind> {
		if (pagefind) return pagefind;
		const pagefindUrl = "/pagefind/pagefind.js";
		const mod = await import(/* @vite-ignore */ pagefindUrl);
		await mod.init();
		pagefind = mod;
		return mod;
	}

	// Document-level keydown: bind once, survives soft-navs. Re-query DOM inside.
	document.addEventListener("keydown", (e) => {
		const input = document.querySelector<HTMLInputElement>("#site-search");
		if (!input) return;
		if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
			e.preventDefault();
			input.focus();
			input.select();
		}
		if (e.key === "Escape" && document.activeElement === input) {
			input.value = "";
			input.blur();
			const resultsEl = document.querySelector<HTMLDivElement>("[data-search-results]");
			const yearGroups = document.querySelectorAll<HTMLDivElement>("[data-year-group]");
			if (resultsEl) resultsEl.hidden = true;
			yearGroups.forEach((el) => (el.hidden = false));
		}
	});

	// Per-page DOM queries + element-scoped listeners. Runs at module load for
	// the initial page, then again on every soft-nav swap (astro:after-swap
	// does NOT fire on initial load, so this is dup-free). On soft-nav the
	// swapped-out DOM elements take their listeners with them — no leaks.
	function initDomListeners() {
		const input = document.querySelector<HTMLInputElement>("#site-search");
		const resultsEl = document.querySelector<HTMLDivElement>("[data-search-results]");
		const filters = document.querySelector<HTMLDivElement>("[data-filters]");
		const yearGroups = document.querySelectorAll<HTMLDivElement>("[data-year-group]");
		const rows = document.querySelectorAll<HTMLElement>("[data-tags]");

		if (!input || !resultsEl || !filters) return;

		function setListVisible(visible: boolean) {
			if (!resultsEl) return;
			resultsEl.hidden = visible;
			yearGroups.forEach((el) => (el.hidden = !visible));
		}

		async function runSearch(query: string) {
			if (!resultsEl) return;
			if (!query.trim()) {
				resultsEl.innerHTML = "";
				setListVisible(true);
				return;
			}
			const pf = await ensurePagefind();
			const { results } = await pf.debouncedSearch(query);
			const items = await Promise.all(results.map((r) => r.data()));
			// item.excerpt is HTML by design — Pagefind owns escaping and wraps
			// matched terms in <mark>. Trust assumes the indexed content is ours.
			resultsEl.innerHTML = items
				.map(
					(item) => `
						<a class="post-row index" href="${escapeAttr(item.url)}" data-testid="post-row">
							<span class="date">${escapeText((item.meta?.date ?? "").slice(0, 10))}</span>
							<div>
								<div class="title">${escapeText(item.meta?.title ?? item.url)}</div>
								<div class="desc">${item.excerpt}</div>
							</div>
						</a>
					`,
				)
				.join("");
			setListVisible(false);
		}

		input.addEventListener("input", () => runSearch(input.value));

		filters.addEventListener("click", (e) => {
			if (!(e.target instanceof Element)) return;
			const btn = e.target.closest<HTMLButtonElement>("button.filter-tag");
			if (!btn) return;
			filters.querySelectorAll(".filter-tag").forEach((el) => el.classList.remove("active"));
			btn.classList.add("active");
			const tag = btn.dataset.tag ?? "__all";
			rows.forEach((row) => {
				const rowTags = (row.dataset.tags ?? "").split(",");
				row.hidden = tag !== "__all" && !rowTags.includes(tag);
			});
		});
	}
	initDomListeners();
	document.addEventListener("astro:after-swap", initDomListeners);
</script>

<style>
	.toolbar {
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 14px 0;
		border-top: 1px solid var(--line-subtle);
		border-bottom: 1px solid var(--line-subtle);
		margin-bottom: 6px;
	}
	.search {
		flex: 1;
		display: flex;
		align-items: center;
		gap: 8px;
		background: var(--surface-02);
		border: 1px solid var(--line);
		border-radius: var(--radius-md);
		padding: 6px 12px;
	}
	.search input {
		background: transparent;
		border: none;
		outline: none;
		color: var(--fg1);
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		flex: 1;
	}
	.search input::placeholder {
		color: var(--fg3);
	}
	.search input::-webkit-search-cancel-button {
		cursor: pointer;
	}
	.kbd-mini {
		font-family: var(--font-mono);
		font-size: var(--text-2xs);
		font-weight: 510;
		background: var(--surface-03);
		border: 1px solid var(--line-subtle);
		padding: 1px 5px;
		border-radius: 3px;
		color: var(--fg3);
	}
	.count {
		font-family: var(--font-sans);
		font-size: var(--text-xs);
		font-weight: 510;
		color: var(--fg3);
		font-variant-numeric: tabular-nums;
	}
	.filters {
		display: flex;
		gap: 8px;
		padding: 16px 0 24px;
		flex-wrap: wrap;
	}
	.filter-tag {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		background: transparent;
		border: 1px solid var(--border-1);
		border-radius: var(--radius-pill);
		padding: 3px 12px 3px 10px;
		font-family: var(--font-sans);
		font-size: var(--text-xs);
		font-weight: 510;
		color: var(--fg2);
		cursor: pointer;
		transition: background 120ms;
	}
	.filter-tag:hover {
		background: var(--surface-03);
	}
	.filter-tag.active {
		background: var(--surface-05);
		color: var(--fg1);
		border-color: var(--line-strong);
	}
	.filter-tag .swatch {
		width: 6px;
		height: 6px;
		border-radius: 50%;
	}
	.filter-tag .num {
		color: var(--fg4);
		font-weight: 400;
		margin-left: 2px;
	}
</style>
