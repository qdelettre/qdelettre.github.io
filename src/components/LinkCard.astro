---
interface Props {
	href: string;
	label: string;
	handle: string;
	external?: boolean;
}
const { href, label, handle, external = false } = Astro.props;
---

<a class="link-card" href={href} {...external && { target: "_blank", rel: "noopener noreferrer" }}>
	<span class="icon" aria-hidden="true"><slot name="icon" /></span>
	<div class="main">
		<div class="label">{label}</div>
		<div class="handle">{handle}</div>
	</div>
	<span class="arrow" aria-hidden="true">→</span>
</a>

<style>
	.link-card {
		display: flex;
		align-items: center;
		gap: 12px;
		background: var(--surface-02);
		border: 1px solid var(--line);
		border-radius: var(--radius-card);
		padding: 12px 14px;
		color: inherit;
		text-decoration: none;
		min-width: 0;
		transition:
			background 120ms,
			border-color 120ms,
			transform 120ms;
	}
	.link-card:hover {
		background: var(--surface-04);
		border-color: var(--line-strong);
	}
	.link-card:active {
		transform: scale(0.96);
	}
	.icon {
		width: 28px;
		height: 28px;
		border-radius: var(--radius-md);
		background: var(--surface-04);
		border: 1px solid var(--line);
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--fg2);
		flex-shrink: 0;
	}
	.main {
		flex: 1;
		min-width: 0;
	}
	.label {
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		font-weight: 510;
		color: var(--fg1);
		letter-spacing: -0.13px;
	}
	.handle {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		font-weight: 400;
		color: var(--fg3);
		margin-top: 2px;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.arrow {
		color: var(--fg4);
	}
</style>
